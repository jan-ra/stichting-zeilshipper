# Generate with:  openssl rand -hex 32
PAYLOAD_SECRET=replace-me-with-a-32-byte-hex-string

# SQLite location. Locally we keep it inside payload/data/. On fly.io this is
# the mounted volume at /data/ — see fly.toml.
DATABASE_URI=file:./data/payload.db

# Public URL clients use to reach this Payload instance. Used by the admin UI
# (links, redirects) and by load-from-payload.mjs to absolutise media URLs.
PAYLOAD_PUBLIC_URL=http://localhost:3001

# ── Media / S3 ────────────────────────────────────────────────────────────────
# Local dev: leave these as-is — MinIO runs on localhost:9000 via docker-compose.
# Production (fly.io): set these as flyctl secrets pointing at Cloudflare R2.

S3_ENDPOINT=http://localhost:9000
S3_BUCKET=zeilshipper-media
S3_REGION=auto
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Public base URL for uploaded files (used in API responses + load-from-payload).
# Local:      http://localhost:9000/zeilshipper-media
# Production: https://media.zeilshipper.nl
MEDIA_BASE_URL=http://localhost:9000/zeilshipper-media

# ── Site rebuild trigger ──────────────────────────────────────────────────────
# Cloudflare Pages Deploy Hook URL. Saving any collection or global in the
# admin POSTs to this URL (debounced), causing a fresh site build.
# Create at: CF Pages → project → Settings → Builds & deployments → Deploy hooks.
# Leave blank locally to disable.
CF_PAGES_DEPLOY_HOOK=
