# Copy this file to .env and fill in your values.
# docker compose reads .env automatically when run from the wordpress/ directory.

# MariaDB
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress

# WordPress initial admin account (created by docker-setup.sh on first start)
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=changeme_admin
WP_ADMIN_EMAIL=admin@localhost

# WordPress content editor account (created by 04-roles.php on first load)
WP_EDITOR_USER=editor
WP_EDITOR_PASSWORD=changeme_editor
WP_EDITOR_EMAIL=editor@localhost

WP_TITLE=Stichting Zeilshipper
