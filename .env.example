# Endpoint the build-time data loader (scripts/load-content.mjs) queries.
# For local development this is the WordPress docker-compose service.
# In CI / Cloudflare Pages, point this at the production WP host.
WP_GRAPHQL_ENDPOINT=http://localhost:8080/graphql

# Endpoint for the Payload variant (scripts/load-from-payload.mjs).
# Locally this is `cd payload && npm run dev`; on fly.io, the deployed app URL.
PAYLOAD_API_URL=http://localhost:3001
# Optional — defaults to PAYLOAD_API_URL. Override when the public URL the
# browser sees differs from the API URL the loader uses.
PAYLOAD_PUBLIC_URL=http://localhost:3001
