# Site-side env (consumed by site/scripts/load-from-payload.mjs).
# CMS-side env lives in cms/.env.example.

# Endpoint the build-time loader queries.
# Locally this is `cd cms && npm run dev`; in production it's the deployed CMS URL.
PAYLOAD_API_URL=http://localhost:3001
# Optional — defaults to PAYLOAD_API_URL. Override when the public URL the
# browser sees differs from the API URL the loader uses.
PAYLOAD_PUBLIC_URL=http://localhost:3001
