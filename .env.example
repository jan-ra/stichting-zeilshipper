# Site-side env (consumed by site/scripts/load-from-payload.mjs and bake-media.mjs).
# CMS-side env lives in cms/.env.example.

# Endpoint the build-time loader queries.
# Locally this is `cd cms && npm run dev`; in production it's the deployed CMS URL.
PAYLOAD_API_URL=http://localhost:3001
# Optional — defaults to PAYLOAD_API_URL. Override when the public URL the
# browser sees differs from the API URL the loader uses.
PAYLOAD_PUBLIC_URL=http://localhost:3001

# Public base URL for media. Used by bake-media.mjs to identify which JSON URLs
# point at the media bucket and should be considered for inlining.
# Local:      http://localhost:9000/zeilshipper-media
# Production: https://media.zeilshipper.nl
MEDIA_BASE_URL=http://localhost:9000/zeilshipper-media

# Max byte size for an image to get baked into the static bundle. Anything
# larger (or any non-image mime) stays on R2 and is loaded at runtime.
BAKE_MAX_BYTES=2097152
